---
import { SEOMetadata } from 'astro-seo-metadata';
import siteLogo from '../assets/logo.png';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string[];
  type?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = "Philosophy Spread | Exploring Wisdom , Inspiring Minds",
  description = "Philosophy Spread explores timeless wisdom, logic modules, and philosophical insights. Join our community of thinkers.",
  image = siteLogo.src,
  keywords = [],
  type = 'website',
  structuredData = [],
} = Astro.props as Props;

const siteUrl = Astro.site ?? new URL('https://philosophyspread.live');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const resolvedImageUrl = image.startsWith('http://') || image.startsWith('https://')
  ? image
  : new URL(image, siteUrl).toString();
const imagePathname = new URL(resolvedImageUrl).pathname.toLowerCase();
const imageType = imagePathname.endsWith('.png')
  ? 'image/png'
  : imagePathname.endsWith('.jpg') || imagePathname.endsWith('.jpeg')
    ? 'image/jpeg'
    : imagePathname.endsWith('.webp')
      ? 'image/webp'
      : imagePathname.endsWith('.gif')
        ? 'image/gif'
        : imagePathname.endsWith('.avif')
          ? 'image/avif'
          : undefined;
const keywordsContent = keywords.join(', ');
const shouldNoindex = Astro.url.hostname !== siteUrl.hostname;

const defaultStructuredData: Array<Record<string, unknown>> = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Philosophy Spread',
    url: siteUrl.toString(),
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Philosophy Spread',
    url: siteUrl.toString(),
    logo: new URL('/favicon.svg', siteUrl).toString(),
    sameAs: [
      'https://www.linkedin.com/in/goeltanmay442/',
      'https://www.instagram.com/gtanmay442',
      'https://x.com/TanmayGoel442',
    ],
  },
];

const additionalStructuredData = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const combinedStructuredData = [...defaultStructuredData, ...additionalStructuredData];
---

<!DOCTYPE html>
<html lang="en" class="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <SEOMetadata
      siteName={'Philosophy Spread'}
      title={title}
      description={description}
      image={resolvedImageUrl}
      favicon={'/favicon.svg'}
      author="Philosophy Spread"
      copyright="2026"
      canonicalUrl={canonicalUrl}
      type={type}
      astroGenerator={true}
    />
    <meta property="og:image:secure_url" content={resolvedImageUrl} />
    {imageType && <meta property="og:image:type" content={imageType} />}
    <meta name="twitter:image" content={resolvedImageUrl} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" type="image/svg+xml" href="/favicon.svg" />
    {keywordsContent && <meta name="keywords" content={keywordsContent} />}
    {shouldNoindex && (
      <>
        <meta name="robots" content="noindex, nofollow" />
        <meta name="googlebot" content="noindex, nofollow" />
      </>
    )}
    {combinedStructuredData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;0,6..72,700;1,6..72,400&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      .material-symbols-outlined {
        font-variation-settings:
          'FILL' 0,
          'wght' 400,
          'GRAD' 0,
          'opsz' 24;
      }
      
      .hard-offset {
        box-shadow: 4px 4px 0px 0px #245ba7;
        transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .hard-offset:hover {
        transform: translateY(-4px);
        box-shadow: 8px 8px 0px 0px #245ba7;
      }
      
      .hard-offset-teal {
        box-shadow: 4px 4px 0px 0px #006b5f;
        transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .hard-offset-teal:hover {
        transform: translateY(-4px);
        box-shadow: 8px 8px 0px 0px #006b5f;
      }

      /* Base Typography */
      body {
        font-family: 'Newsreader', serif;
        background-color: #f8f9ff;
        color: #0c1c2e;
        line-height: 1.7;
      }

      /* Headings - higher contrast */
      h1, .h1 {
        color: #006b5f !important;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      h2, .h2 {
        color: #245ba7 !important;
        font-weight: 600;
      }

      h3, .h3 {
        color: #006b5f !important;
        font-weight: 600;
      }

      /* Body text - higher contrast for readability */
      p, article {
        color: #0c1c2e !important;
      }

      /* Links */
      a {
        color: #245ba7;
        text-decoration: none;
      }
      a:hover {
        color: #006b5f;
        text-decoration: underline;
      }

      /* Selection */
      ::selection {
        background-color: #8ef5e3;
        color: #0c1c2e;
      }

      /* No border radius anywhere */
      * {
        border-radius: 0px !important;
      }

      /* Component backgrounds */
      .card, .quiz-container, blockquote, pre, code {
        background-color: #ffffff !important;
      }

      /* Borders */
      hr, .border {
        border-color: #6d7a77 !important;
      }
    </style>
  </head>
  <body class="bg-background text-on-surface min-h-screen">
    <slot />
  </body>
</html>
