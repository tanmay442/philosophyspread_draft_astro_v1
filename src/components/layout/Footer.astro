---

<footer class="relative grid grid-cols-1 gap-12 border-t-2 border-secondary bg-surface-container-low px-6 py-16 md:grid-cols-3 md:px-12">
  <div class="space-y-4">
    <div class="font-headline text-2xl italic text-secondary">Philosophy Spread</div>
    <p class="font-body text-sm leading-relaxed text-on-surface-variant opacity-80">
      Aiming to spread wisdom and inspire change. This journey begins with a simple effort to make philosophical insights more accessible, fostering a more thoughtful and critical community.
    </p>
  </div>

  <div class="space-y-6">
    <div class="space-y-3">
      <h2 class="font-label text-xs font-bold uppercase tracking-widest text-primary">Policies</h2>
      <ul class="flex flex-col space-y-1">
        <li><a href="/terms" class="font-body text-sm text-secondary transition-all hover:text-primary">Terms & Privacy Policy</a></li>
      </ul>
    </div>

    <div class="space-y-3">
      <h2 class="font-label text-xs font-bold uppercase tracking-widest text-primary">How to Contribute</h2>
      <ul class="flex flex-col space-y-1">
        <li><a href="/contribute" class="font-body text-sm text-secondary transition-all hover:text-primary">Contribute Content</a></li>
        <li><a href="/authors" class="font-body text-sm text-secondary transition-all hover:text-primary">Authors</a></li>
      </ul>
    </div>
  </div>

  <div class="flex flex-col space-y-6 md:items-end md:text-right">
    <div>
      <h2 class="font-headline text-lg text-secondary">Tanmay Goel</h2>
      <p class="font-body text-xs text-on-surface-variant">goeltanmay442@outlook.com</p>
    </div>

    <div>
      <h2 class="mb-3 font-label text-xs font-bold uppercase tracking-widest text-primary">My Current Journey</h2>
      <p class="font-body text-sm leading-relaxed text-on-surface-variant opacity-80">
        I am a student pursuing a double major in Mathematics and Data Science with a strong interest in Philosophy, ethics, and critical logic. My aim is to develop a community of like-minded people to learn and grow with.
      </p>
    </div>

    <div>
      <h2 class="mb-3 font-label text-xs font-bold uppercase tracking-widest text-primary">Connect With Me</h2>
      <div class="flex justify-start gap-4 md:justify-end">
        {socialLinks.map(({ href, label, path }) => (
          <a
            href={href}
            target="_blank"
            rel="noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-secondary/30 bg-surface-container transition-all hover:border-primary hover:bg-primary/10"
            aria-label={label}
          >
            <svg class="h-5 w-5 text-secondary hover:text-primary" fill="currentColor" viewBox="0 0 24 24">
              <path d={path} />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="md:col-span-3 mt-4 border-t border-secondary/30 pt-8">
    <p class="text-center font-label text-xs text-on-surface-variant opacity-70 md:text-left">
      © 2025 Philosophy Spread • Aiming to foster a thoughtful world.
    </p>
  </div>

  <a
    href="#"
    class="absolute bottom-8 right-8 z-10 border-2 border-surface bg-primary p-4 text-on-primary transition-colors hover:bg-secondary hover:text-on-secondary"
    aria-label="Scroll to top"
  >
    <Icon name="arrow_upward" class="block h-5 w-5" />
  </a>
</footer>
