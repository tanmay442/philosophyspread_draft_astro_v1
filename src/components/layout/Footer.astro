      © 2024 Philosophy Spread. All rights reserved.
    </div>
  </div>
</footer>

<!-- Floating Top Arrow -->
<a href="#" id="back-to-top" class="fixed bottom-8 right-8 bg-primary text-on-primary p-4 z-50 hover:bg-secondary transition-colors border-2 border-white hard-offset-teal opacity-0 pointer-events-none transition-opacity duration-500">
  <span class="material-symbols-outlined block">arrow_upward</span>
</a>

<script>
  const backToTopBtn = document.getElementById('back-to-top');
  if (backToTopBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 1000) {
        backToTopBtn.classList.remove('opacity-0', 'pointer-events-none');
        backToTopBtn.classList.add('opacity-100');
      } else {
        backToTopBtn.classList.add('opacity-0', 'pointer-events-none');
        backToTopBtn.classList.remove('opacity-100');
      }
    });
  }
</script>
