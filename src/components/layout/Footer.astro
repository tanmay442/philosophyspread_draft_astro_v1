---
import Icon from '../ui/Icon.astro';
---

<footer class="relative bg-surface-container-low dark:bg-slate-900 border-t-2 border-secondary grid grid-cols-1 md:grid-cols-3 gap-12 px-6 md:px-12 py-16">
  
  <!-- Column 1: Philosophy Spread -->
  <div class="space-y-4">
    <div class="font-headline italic text-2xl text-secondary">Philosophy Spread</div>
    <p class="font-body text-sm text-on-surface-variant opacity-80 leading-relaxed">
      Aiming to spread wisdom and inspire change. This journey begins with a simple effort to make philosophical insights more accessible, fostering a more thoughtful and critical community.
    </p>
  </div>
       
  <!-- Column 2: Policies + Contribute -->
  <div class="space-y-6">
    <div class="space-y-3">
      <h4 class="font-label uppercase tracking-widest text-xs font-bold text-primary">Policies</h4>
      <ul class="space-y-1 flex flex-col">
        <li><a href="/terms" class="font-body text-sm text-secondary hover:text-primary transition-all">Terms & Privacy Policy</a></li>
      </ul>
    </div>
    
    <div class="space-y-3">
      <h4 class="font-label uppercase tracking-widest text-xs font-bold text-primary">How to Contribute</h4>
      <ul class="space-y-1 flex flex-col">
        <li><a href="/contribute" class="font-body text-sm text-secondary hover:text-primary transition-all">Contribute Content</a></li>
      </ul>
    </div>
  </div>
       
  <!-- Column 3: Connect -->
  <div class="flex flex-col md:items-end md:text-right space-y-6">
    <div>
      <h3 class="font-headline text-lg text-secondary">Tanmay Goel</h3>
      <p class="font-body text-xs text-on-surface-variant">goeltanmay442@outlook.com</p>
    </div>
    
    <div>
        <h4 class="font-label uppercase tracking-widest text-xs font-bold text-primary mb-3">My Current Journey</h4>
        <p class="font-body text-sm text-on-surface-variant opacity-80 leading-relaxed">
          I am a student pursuing a double major in Mathematics and Data Science with a strong interest in Philosophy, ethics, and critical logic. My aim is to develop a community of like-minded people to learn and grow with.
        </p>
    </div>

    <div>
        <h4 class="font-label uppercase tracking-widest text-xs font-bold text-primary mb-3">Connect With Me</h4>
        <div class="flex gap-4 justify-start md:justify-end">
        <a 
          href="https://www.linkedin.com/in/goeltanmay442/" 
          target="_blank" 
          rel="noreferrer"
          class="flex items-center justify-center w-10 h-10 rounded-full bg-surface-container border border-secondary/30 hover:border-primary hover:bg-primary/10 transition-all"
          aria-label="LinkedIn"
        >
          <svg class="w-5 h-5 text-secondary hover:text-primary" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        
        <a 
          href="https://www.instagram.com/gtanmay442" 
          target="_blank" 
          rel="noreferrer"
          class="flex items-center justify-center w-10 h-10 rounded-full bg-surface-container border border-secondary/30 hover:border-primary hover:bg-primary/10 transition-all"
          aria-label="Instagram"
        >
          <svg class="w-5 h-5 text-secondary hover:text-primary" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        
        <a 
          href="https://x.com/TanmayGoel442" 
          target="_blank" 
          rel="noreferrer"
          class="flex items-center justify-center w-10 h-10 rounded-full bg-surface-container border border-secondary/30 hover:border-primary hover:bg-primary/10 transition-all"
          aria-label="Twitter/X"
        >
          <svg class="w-5 h-5 text-secondary hover:text-primary" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="md:col-span-3 border-t border-secondary/30 pt-8 mt-4">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="font-label text-xs text-on-surface-variant opacity-70 text-center md:text-left">
        © 2026 Philosophy Spread • Aiming to foster a thoughtful world.
      </p>
    </div>
  </div>

  <!-- Scroll to Top -->
  <a 
    href="#"
    class="absolute bottom-8 right-8 bg-primary text-on-primary p-4 z-10 hover:bg-secondary hover:text-on-secondary transition-colors border-2 border-surface"
  >
    <Icon name="arrow_upward" class="block h-5 w-5" />
  </a>
</footer>
