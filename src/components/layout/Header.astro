---
import Button from '../ui/Button.astro';
import { SignInButton, Show, UserButton } from '@clerk/astro/components';
import { Image } from 'astro:assets';
import logoRemoveBg from '/logo-removebg.png';

const pathname = Astro.url.pathname;
const currentPath = pathname.slice(1); // remove leading slash
const returnTo = `${Astro.url.pathname}${Astro.url.search}`;
---

<header class="fixed top-0 w-full z-50 bg-surface dark:bg-slate-950 border-b-2 border-secondary shadow-[1px_1px_0px_#245ba7]">
  <div class="max-w-7xl mx-auto flex justify-between items-center px-4 py-2 w-full relative z-50 bg-surface">
    <a href="/" class="flex items-center hover:opacity-90 transition-opacity shrink-0">
      <span class="block h-10 w-[200px] sm:h-12 sm:w-[240px]">
        <Image
          src={logoRemoveBg}
          alt="Philosophy Spread"
          width={594}
          height={109}
          loading="eager"
          fetchpriority="high"
          sizes="(min-width: 640px) 240px, 200px"
          class="h-full w-full object-contain"
        />
      </span>
    </a>
    
    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center space-x-8">
      <a class={`font-label text-xs tracking-widest uppercase transition-colors ${currentPath.startsWith('logic-modules') ? 'text-primary border-b-2 border-primary font-bold' : 'text-secondary hover:text-primary'}`} href="/logic-modules">Logic and Reasoning</a>
      <a class={`font-label text-xs tracking-widest uppercase transition-colors ${currentPath.startsWith('bits') ? 'text-primary border-b-2 border-primary font-bold' : 'text-secondary hover:text-primary'}`} href="/bits/page/1">48hrs-bits</a>
      <a class="font-label text-xs tracking-widest uppercase text-secondary hover:text-primary transition-colors" href="/#trials">Idea Trials</a>
      <a class={`font-label text-xs tracking-widest uppercase transition-colors ${currentPath.startsWith('essays') ? 'text-primary border-b-2 border-primary font-bold' : 'text-secondary hover:text-primary'}`} href="/essays/page/1">Essays</a>
    </nav>
    <div class="hidden lg:flex items-center space-x-3">
      <Show when="signed-out">
        <SignInButton
          asChild
          mode="modal"
          forceRedirectUrl={returnTo}
          signUpForceRedirectUrl={returnTo}
          fallbackRedirectUrl={returnTo}
          signUpFallbackRedirectUrl={returnTo}
        >
          <Button variant="primary">SUBSCRIBE</Button>
        </SignInButton>
      </Show>
      <Show when="signed-in">
        <div class="flex items-center gap-2">
          <!-- Compact Thank You Message -->
          <div class="flex flex-col items-end justify-center w-[70px]">
            <span class="text-[9px] font-bold uppercase tracking-widest text-primary leading-tight">Thank you</span>
            <span class="text-[10px] italic text-secondary font-medium leading-tight">for joining!</span>
          </div>
          <!-- Clerk Component -->
          <UserButton 
            appearance={{ elements: { userButtonAvatarBox: "w-8 h-8" } }} 
          />
        </div>
      </Show>
    </div>

    <!-- Mobile Menu Toggle -->
    <button id="mobile-menu-toggle" class="lg:hidden flex items-center justify-center p-2 text-secondary hover:text-primary transition-colors" aria-label="Toggle Menu">
      <span class="material-symbols-outlined text-3xl menu-icon">menu</span>
    </button>
  </div>

  <!-- Mobile Menu Backdrop -->
  <div id="mobile-menu-backdrop" class="fixed inset-0 bg-secondary/20 backdrop-blur-sm z-30 hidden"></div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed top-0 right-0 h-full w-[85vw] md:w-[60vw] bg-surface z-40 hidden flex-col pt-24 px-6 pb-8 overflow-y-auto border-l-2 border-secondary shadow-2xl">
    <nav class="flex flex-col space-y-6 mt-4 flex-grow">
      <a class={`font-headline text-3xl uppercase tracking-widest border-b-2 border-secondary pb-4 transition-colors ${currentPath.startsWith('logic-modules') ? 'text-primary italic' : 'text-secondary hover:text-primary'}`} href="/logic-modules">Logic and Reasoning</a>
      <a class={`font-headline text-3xl uppercase tracking-widest border-b-2 border-secondary pb-4 transition-colors ${currentPath.startsWith('bits') ? 'text-primary italic' : 'text-secondary hover:text-primary'}`} href="/bits/page/1">48hrs-bits</a>
      <a class="font-headline text-3xl uppercase tracking-widest border-b-2 border-secondary pb-4 text-secondary hover:text-primary transition-colors" href="/#trials">Idea Trials</a>
      <a class={`font-headline text-3xl uppercase tracking-widest border-b-2 border-secondary pb-4 transition-colors ${currentPath.startsWith('essays') ? 'text-primary italic' : 'text-secondary hover:text-primary'}`} href="/essays/page/1">Essays</a>
    </nav>
    <div class="mt-auto pt-8">
      <Show when="signed-out">
        <SignInButton
          asChild
          mode="modal"
          forceRedirectUrl={returnTo}
          signUpForceRedirectUrl={returnTo}
          fallbackRedirectUrl={returnTo}
          signUpFallbackRedirectUrl={returnTo}
        >
          <Button variant="primary" class="w-full flex justify-center text-lg py-4">SUBSCRIBE</Button>
        </SignInButton>
      </Show>
      <Show when="signed-in">
        <div class="flex items-center justify-between border-2 border-secondary/20 bg-secondary/5 rounded-2xl p-4 w-full">
          <div class="flex flex-col">
            <span class="text-[11px] font-bold uppercase tracking-widest text-primary leading-tight">Thank you</span>
            <span class="text-sm italic text-secondary font-medium leading-tight mt-1">for joining!</span>
          </div>
          <UserButton appearance={{ elements: { userButtonAvatarBox: "w-10 h-10" } }} />
        </div>
      </Show>
    </div>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const menuIcon = toggleBtn?.querySelector('.menu-icon');

  function toggleMenu() {
    const isHidden = mobileMenu?.classList.contains('hidden');
    if (isHidden) {
      mobileMenu?.classList.remove('hidden');
      mobileMenu?.classList.add('flex');
      backdrop?.classList.remove('hidden');
      if (menuIcon) menuIcon.textContent = 'close';
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex');
      backdrop?.classList.add('hidden');
      if (menuIcon) menuIcon.textContent = 'menu';
      document.body.style.overflow = '';
    }
  }

  toggleBtn?.addEventListener('click', toggleMenu);
  backdrop?.addEventListener('click', toggleMenu);

  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', toggleMenu);
  });
</script>

<style is:global>
  /* Clerk UserButton perfectly round styling */
  .clerk-user-button {
    border: 2px solid #006b5f !important;
    border-radius: 9999px !important;
    padding: 2px !important;
    overflow: hidden !important;
    aspect-ratio: 1 / 1 !important; /* Force a perfect square wrapper to prevent stretching */
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
  
  .clerk-user-button:hover {
    background-color: #006b5f !important;
  }
  
  .clerk-user-button svg,
  .clerk-user-button img {
    border-radius: 9999px !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
  
  /* Clerk dropdown styling */
  .clerk-dropdown {
    border: 2px solid #006b5f !important;
    border-radius: 8px !important;
  }
  
  .clerk-popover {
    border: 2px solid #006b5f !important;
    border-radius: 8px !important;
  }
  
  .clerk-popover a,
  .clerk-popover button {
    border-radius: 4px !important;
  }
</style>