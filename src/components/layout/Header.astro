---
import { SignInButton, Show, UserButton } from '@clerk/astro/components';
import logoRemoveBg from '../../assets/logo-removebg.avif';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

const currentPath = Astro.url.pathname.replace(/^\//, '');
const returnTo = `${Astro.url.pathname}${Astro.url.search}`;

const navigationLinks = [
  { href: '/logic-modules', label: 'Logic and Reasoning', segment: 'logic-modules' },
  { href: '/bits/page/1', label: 'Idea-Bits', segment: 'bits' },
  { href: '/essays/page/1', label: 'Essays', segment: 'essays' },
];

const signInRedirectProps = {
  forceRedirectUrl: returnTo,
  signUpForceRedirectUrl: returnTo,
  fallbackRedirectUrl: returnTo,
  signUpFallbackRedirectUrl: returnTo,
};

const desktopLinkClass = (segment: string) =>
  `font-label text-xs uppercase tracking-widest transition-colors ${
    currentPath.startsWith(segment)
      ? 'text-primary border-b-2 border-primary font-bold'
      : 'text-secondary hover:text-primary'
  }`;

const mobileLinkClass = (segment: string) =>
  `font-headline text-3xl uppercase tracking-widest border-b-2 border-secondary pb-4 transition-colors ${
    currentPath.startsWith(segment) ? 'text-primary italic' : 'text-secondary hover:text-primary'
  }`;
---

<header class="fixed top-0 z-50 w-full border-b-2 border-secondary bg-surface shadow-[1px_1px_0px_#245ba7]">
  <div class="relative z-50 mx-auto flex w-full max-w-7xl items-center justify-between bg-surface px-4 py-2">
    <a href="/" class="shrink-0 transition-opacity hover:opacity-90" aria-label="Philosophy Spread home">
      <span class="block h-10 w-[200px] sm:h-12 sm:w-[240px]">
        <img
          src={logoRemoveBg.src}
          alt="Philosophy Spread"
          width={594}
          height={109}
          loading="eager"
          fetchpriority="high"
          class="h-full w-full object-contain"
        />
      </span>
    </a>

    <nav class="hidden items-center space-x-8 lg:flex">
      {navigationLinks.map(({ href, label, segment }) => (
        <a class={desktopLinkClass(segment)} href={href}>{label}</a>
      ))}
    </nav>

    <div class="hidden items-center space-x-3 lg:flex">
      <Show when="signed-out">
        <SignInButton asChild mode="modal" {...signInRedirectProps}>
          <Button variant="primary">SUBSCRIBE</Button>
        </SignInButton>
      </Show>
      <Show when="signed-in">
        <div class="flex items-center gap-2">
          <div class="flex w-[70px] flex-col items-end justify-center">
            <span class="text-[9px] font-bold uppercase leading-tight tracking-widest text-primary">Thank you</span>
            <span class="text-[10px] font-medium italic leading-tight text-secondary">for joining!</span>
          </div>
          <UserButton appearance={{ elements: { userButtonAvatarBox: 'w-8 h-8' } }} />
        </div>
      </Show>
    </div>

    <button
      id="mobile-menu-toggle"
      class="flex items-center justify-center p-2 text-secondary transition-colors hover:text-primary lg:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <Icon name="menu" class="menu-icon h-8 w-8" />
      <Icon name="close" class="close-icon hidden h-8 w-8" />
    </button>
  </div>

  <div id="mobile-menu-backdrop" class="fixed inset-0 z-30 hidden bg-secondary/20 backdrop-blur-sm" aria-hidden="true"></div>

  <div
    id="mobile-menu"
    class="fixed right-0 top-0 z-40 hidden h-full w-[85vw] flex-col overflow-y-auto border-l-2 border-secondary bg-surface px-6 pb-8 pt-24 shadow-2xl md:w-[60vw]"
  >
    <nav class="mt-4 flex flex-grow flex-col space-y-6">
      {navigationLinks.map(({ href, label, segment }) => (
        <a class={mobileLinkClass(segment)} href={href}>{label}</a>
      ))}
    </nav>

    <div class="mt-auto pt-8">
      <Show when="signed-out">
        <SignInButton asChild mode="modal" {...signInRedirectProps}>
          <Button variant="primary" class="flex w-full justify-center py-4 text-lg">SUBSCRIBE</Button>
        </SignInButton>
      </Show>
      <Show when="signed-in">
        <div class="flex w-full items-center justify-between border-2 border-secondary/20 bg-secondary/5 p-4">
          <div class="flex flex-col">
            <span class="text-[11px] font-bold uppercase leading-tight tracking-widest text-primary">Thank you</span>
            <span class="mt-1 text-sm font-medium italic leading-tight text-secondary">for joining!</span>
          </div>
          <UserButton appearance={{ elements: { userButtonAvatarBox: 'w-10 h-10' } }} />
        </div>
      </Show>
    </div>
  </div>
</header>

<script>
  const toggleButton = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const menuIcon = toggleButton?.querySelector('.menu-icon');
  const closeIcon = toggleButton?.querySelector('.close-icon');

  const setMenuOpen = (isOpen: boolean) => {
    if (!mobileMenu || !backdrop || !toggleButton) {
      return;
    }

    mobileMenu.classList.toggle('hidden', !isOpen);
    mobileMenu.classList.toggle('flex', isOpen);
    backdrop.classList.toggle('hidden', !isOpen);
    menuIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
    toggleButton.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  };

  const toggleMenu = () => {
    const isOpen = mobileMenu?.classList.contains('flex') ?? false;
    setMenuOpen(!isOpen);
  };

  toggleButton?.addEventListener('click', toggleMenu);
  backdrop?.addEventListener('click', () => setMenuOpen(false));
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });
</script>

<style is:global>
  .clerk-user-button {
    display: flex !important;
    aspect-ratio: 1 / 1 !important;
    align-items: center !important;
    justify-content: center !important;
    overflow: hidden !important;
    border: 2px solid #006b5f !important;
    border-radius: 9999px !important;
    padding: 2px !important;
  }

  .clerk-user-button:hover {
    background-color: #006b5f !important;
  }

  .clerk-user-button svg,
  .clerk-user-button img {
    width: 100% !important;
    height: 100% !important;
    border-radius: 9999px !important;
    object-fit: cover !important;
  }

  .clerk-dropdown,
  .clerk-popover {
    border: 2px solid #006b5f !important;
    border-radius: 8px !important;
  }

  .clerk-popover a,
  .clerk-popover button {
    border-radius: 4px !important;
  }
</style>
