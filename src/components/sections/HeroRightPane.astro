---
import { getCollection, type CollectionEntry } from 'astro:content';
import HeroBlock from '../cards/HeroBlock.astro';

const pickLatest = <T,>(items: T[], compareFn: (a: T, b: T) => number): T | undefined => {
  if (!items.length) {
    return undefined;
  }

  return items.slice(1).reduce(
    (latestItem, item) => (compareFn(item, latestItem) < 0 ? item : latestItem),
    items[0],
  );
};

const logicModules = await getCollection('logicModules');
const latestLogic = pickLatest(
  logicModules,
  (a: CollectionEntry<'logicModules'>, b: CollectionEntry<'logicModules'>) =>
    b.data.moduleNumber.localeCompare(a.data.moduleNumber),
);

const bits = await getCollection('bits');
const latestBit = pickLatest(
  bits,
  (a: CollectionEntry<'bits'>, b: CollectionEntry<'bits'>) =>
    b.data.timestamp.valueOf() - a.data.timestamp.valueOf(),
);

const essays = await getCollection('essays');
const latestEssay = pickLatest(
  essays,
  (a: CollectionEntry<'essays'>, b: CollectionEntry<'essays'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const truncateText = (value: string, maxLength: number) =>
  value.length > maxLength ? `${value.slice(0, maxLength)}...` : value;
---

<div class="md:col-span-4 flex flex-col bg-surface-container-low">
  {latestLogic && (
    <HeroBlock 
      tag={`MODULE ${latestLogic.data.moduleNumber}`}
      title={latestLogic.data.title}
      description={latestLogic.data.description}
      bgClass="bg-[#D3E3FC]"
      hoverBgClass="hover:bg-[#FFCCBC] hover:-translate-y-1"
      href={`/logic-modules/${latestLogic.id}`}
    />
  )}
  
  {latestBit && (
    <HeroBlock 
      tag={`BIT ${latestBit.data.bitNumber}`}
      title={latestBit.data.category}
      description={truncateText(latestBit.data.content, 100)}
      bgClass="bg-[#FFFFFF]"
      hoverBgClass="hover:bg-[#00887A]/10 hover:-translate-y-1"
      href={`/bits/${latestBit.id}`}
    />
  )}
  
  {latestEssay && (
    <HeroBlock 
      tag={`ESSAY`}
      title={latestEssay.data.title}
      description={latestEssay.data.description}
      bgClass="bg-[#FFCCBC]"
      hoverBgClass="hover:bg-[#D3E3FC] hover:-translate-y-1"
      hoverTextClass="hover:text-white"
      href={`/essays/${latestEssay.id}`}
    />
  )}
</div>
