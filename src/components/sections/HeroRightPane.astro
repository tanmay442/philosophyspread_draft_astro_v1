---
import HeroBlock from '../cards/HeroBlock.astro';
---

<div class="md:col-span-4 flex flex-col bg-surface-container-low">
  <!-- Block 1: Logic Module (Ice Blue) -->
  <HeroBlock 
    tag="MODULE L-01"
    title="Formal Syllogisms"
    description="Deconstruct arguments into their base premises to find the objective truth hidden in rhetoric."
    bgClass="bg-[#D3E3FC]"
    hoverBgClass="hover:bg-[#FFCCBC] hover:-translate-y-1"
  />
  
  <!-- Block 2: 48hrs-bits (White) -->
  <HeroBlock 
    tag="BIT B-48"
    title="The Premeditation of Evils"
    description="Stoic visualization techniques to armor the mind against the chaos of chance."
    bgClass="bg-[#FFFFFF]"
    hoverBgClass="hover:bg-[#00887A]/10 hover:-translate-y-1"
  />
  
  <!-- Block 3: Essays Teaser (Muted Peach) -->
  <HeroBlock 
    tag="ESSAY E-12"
    title="The Inner Citadel"
    description="A meditation on maintaining psychological sovereignty in an era of persistent digital noise."
    bgClass="bg-[#FFCCBC]"
    hoverBgClass="hover:bg-[#006b5f] hover:-translate-y-1"
    hoverTextClass="hover:text-white"
  />
</div>
