---
import Button from '../ui/Button.astro';
import ContributeModal from '../ui/ContributeModal.astro';
import { SignInButton } from '@clerk/astro/components';

const returnTo = `${Astro.url.pathname}${Astro.url.search}`;
---

<section class="py-32 px-8 md:px-12 bg-secondary text-white [&_h2]:!text-white [&_p]:!text-white">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="font-headline text-6xl mb-8" >Get Involved With Us</h2>
    <p class="font-body text-2xl opacity-90 mb-12 leading-relaxed">
      Your support is vital to our mission of fostering a thoughtful world. Join our network of thinkers, writers, and students dedicated to the rigorous pursuit of wisdom.
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-6">
      <Button variant="tertiary" data-modal="contribute">Learn How to Contribute</Button>
      <SignInButton
        asChild
        mode="modal"
        forceRedirectUrl={returnTo}
        signUpForceRedirectUrl={returnTo}
        fallbackRedirectUrl={returnTo}
        signUpFallbackRedirectUrl={returnTo}
      >
        <Button variant="secondary">Subscribe</Button>
      </SignInButton>
    </div>
  </div>
</section>

<ContributeModal />
