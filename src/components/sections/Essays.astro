---
import FeaturedEssay from '../cards/FeaturedEssay.astro';
import TrendingList from './TrendingList.astro';
import SubmitEssayCard from '../cards/SubmitEssayCard.astro';
import Icon from '../ui/Icon.astro';
---

<section id="essays" class="py-24 px-8 md:px-12 bg-surface-container-low border-t-2 border-secondary">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-12">
      <h2 class="font-headline text-5xl">Essays</h2>
      <a href="/essays/page/1" class="hidden md:flex font-label text-xs text-secondary uppercase tracking-[0.3em] hover:text-primary transition-colors items-center group">
        View All Essays 
        <Icon name="arrow_forward" class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <FeaturedEssay />
      
      <div class="md:col-span-4 flex flex-col">
        <TrendingList />
        <SubmitEssayCard />
      </div>
    </div>

    <div class="mt-12 flex md:hidden justify-center">
      <a href="/essays/page/1" class="font-label text-xs text-secondary uppercase tracking-[0.3em] hover:text-primary transition-colors flex items-center group">
        View All Essays 
        <Icon name="arrow_forward" class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</section>
