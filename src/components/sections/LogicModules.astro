---
import { getCollection } from 'astro:content';
import LogicCard from '../cards/LogicCard.astro';
import Icon from '../ui/Icon.astro';

const logicModules = await getCollection('logicModules');
const sortedModules = logicModules.sort((a, b) => a.data.moduleNumber.localeCompare(b.data.moduleNumber)).slice(0, 4);
---

<section id="logic" class="py-24 px-8 md:px-12 bg-surface">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12 md:mb-16 border-l-4 border-primary pl-6 flex justify-between items-end md:pr-4">
      <div>
        <h2 class="font-label text-sm text-primary mb-2 uppercase tracking-[0.3em]">Foundation</h2>
        <h3 class="font-headline text-5xl">Master the Fundamentals</h3>
      </div>
      <a href="/logic-modules" class="hidden md:flex font-label text-xs text-secondary uppercase tracking-[0.3em] hover:text-primary transition-colors items-center group">
        View All Modules 
        <Icon name="arrow_forward" class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {sortedModules.map((module) => (
        <a href={`/logic-modules/${module.id}`} class="block group">
          <LogicCard 
            moduleNumber={module.data.moduleNumber}
            title={module.data.title} 
            description={module.data.description} 
          />
        </a>
      ))}
    </div>

    <div class="mt-8 flex md:hidden justify-center">
      <a href="/logic-modules" class="font-label text-xs text-secondary uppercase tracking-[0.3em] hover:text-primary transition-colors flex items-center group">
        View All Modules 
        <Icon name="arrow_forward" class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</section>
