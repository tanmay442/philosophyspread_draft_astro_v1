---
interface Props {
  name: string;
  class?: string;
  title?: string;
}

const { name, class: className = '', title } = Astro.props as Props;

const iconPaths: Record<string, string[]> = {
  arrow_back: ['M19 12H5', 'M12 19L5 12L12 5'],
  arrow_forward: ['M5 12H19', 'M12 5L19 12L12 19'],
  check: ['M20 6L9 17L4 12'],
  bolt: ['M13 2L4 14H11L10 22L20 10H13Z'],
  menu: ['M4 6H20', 'M4 12H20', 'M4 18H20'],
  close: ['M6 6L18 18', 'M18 6L6 18'],
  arrow_upward: ['M12 19V5', 'M5 12L12 5L19 12'],
  open_in_new: ['M14 5H19V10', 'M10 14L19 5', 'M19 14V19H5V5H10'],
  format_quote: ['M9 7H5V13H9L7 17H11L13 13V7H9Z', 'M17 7H13V13H17L15 17H19L21 13V7H17Z'],
};

const paths = iconPaths[name] ?? iconPaths.open_in_new;
const decorative = !title;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden={decorative ? 'true' : undefined}
  role={decorative ? undefined : 'img'}
>
  {title && <title>{title}</title>}
  {paths.map((path) => <path d={path} />)}
</svg>
