---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-12">
  <img 
    src={src} 
    alt={alt} 
    class="w-full object-cover border-2 border-secondary filter grayscale contrast-125"
    referrerpolicy="no-referrer"
  />
  {caption && (
    <figcaption class="mt-4 font-body text-sm italic text-on-surface-variant text-center">
      {caption}
    </figcaption>
  )}
</figure>
