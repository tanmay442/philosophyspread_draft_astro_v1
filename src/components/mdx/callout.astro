---
interface Props {
  type?: 'example' | 'info' | 'warning';
  title?: string;
}

const { type = 'example', title } = Astro.props;

// Map the types to your specific Tailwind design system classes
const containerStyles = {
  example: 'bg-surface-container-low border-2 border-secondary',
  info: 'bg-primary/10 border-l-4 border-primary',
  warning: 'bg-error/10 border-l-4 border-error', // Extrapolated for future use
};

const titleStyles = {
  example: 'text-primary',
  info: 'text-primary',
  warning: 'text-error',
};
---

<div class={`p-6 my-8 ${containerStyles[type]}`}>
  {title && (
    <p class={`font-semibold mb-2 ${titleStyles[type]}`}>
      {title}
    </p>
  )}
  {/* The <slot /> tag injects whatever markdown you write inside the component */}
  <div class="space-y-4">
    <slot />
  </div>
</div>