---
interface Step {
  line: string;
  formula: string;
  justification: string;
  isConclusion?: boolean;
  scopeDepth?: number;
}

interface Props {
  steps: Step[];
  showScope?: boolean;
}

const { steps, showScope = false } = Astro.props;

const SCOPE_COLUMN_WIDTH_PX = 28;
const SCOPE_TEXT_GAP_PX = 10;
const SCOPE_LINE_OFFSET_PX = 14;

const getScopeDepth = (step: Step) => {
  if (!showScope || step.scopeDepth === undefined) return 0;
  return Math.max(0, Math.floor(step.scopeDepth));
};

const getScopePaddingStyle = (depth: number) => {
  if (depth === 0) return '';
  return `padding-left: ${depth * SCOPE_COLUMN_WIDTH_PX + SCOPE_TEXT_GAP_PX}px;`;
};

const getScopeLineStyle = (scopeIndex: number) => `left: ${scopeIndex * SCOPE_COLUMN_WIDTH_PX + SCOPE_LINE_OFFSET_PX}px;`;
---

<div class="my-8 overflow-x-auto bg-surface-container-low border-2 border-secondary p-4 md:p-6">
  <table class="w-full text-left">
    <thead>
      <tr class="border-b-2 border-secondary">
        <th class="p-2 md:p-3 font-label text-xs uppercase tracking-widest text-primary w-16">Line</th>
        <th class="p-2 md:p-3 font-label text-xs uppercase tracking-widest text-primary">Statement</th>
        <th class="p-2 md:p-3 font-label text-xs uppercase tracking-widest text-primary">Justification</th>
      </tr>
    </thead>
    <tbody>
      {steps.map((step) => (
        <tr class={`border-b border-secondary/30 ${step.isConclusion ? 'bg-secondary/10' : ''}`}>
          <td class="p-2 md:p-3 font-label text-sm text-secondary">{step.line}</td>
          <td class={`p-2 md:p-3 font-mono text-lg ${step.isConclusion ? 'text-secondary font-bold' : 'text-on-surface'}`}>
            {showScope ? (
              <div class="relative" style={getScopePaddingStyle(getScopeDepth(step))}>
                {Array.from({ length: getScopeDepth(step) }).map((_, scopeIndex) => (
                  <span
                    aria-hidden="true"
                    class="absolute -top-3 -bottom-3 w-[2px] bg-primary/70"
                    style={getScopeLineStyle(scopeIndex)}
                  ></span>
                ))}
                <span class="relative z-10">{step.formula}</span>
              </div>
            ) : (
              step.formula
            )}
          </td>
          <td class="p-2 md:p-3 font-body text-sm text-on-surface-variant italic">{step.justification}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
