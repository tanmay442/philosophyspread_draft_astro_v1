---
interface Step {
  line: string;
  formula: string;
  justification: string;
  isConclusion?: boolean;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<div class="my-8 overflow-x-auto bg-surface-container-low border-2 border-secondary p-4 md:p-6">
  <table class="w-full text-left">
    <thead>
      <tr class="border-b-2 border-secondary">
        <th class="p-2 md:p-3 font-label text-xs uppercase tracking-widest text-primary w-16">Line</th>
        <th class="p-2 md:p-3 font-label text-xs uppercase tracking-widest text-primary">Statement</th>
        <th class="p-2 md:p-3 font-label text-xs uppercase tracking-widest text-primary">Justification</th>
      </tr>
    </thead>
    <tbody>
      {steps.map((step, index) => (
        <tr class={`border-b border-secondary/30 ${step.isConclusion ? 'bg-secondary/10' : ''}`}>
          <td class="p-2 md:p-3 font-label text-sm text-secondary">{step.line}</td>
          <td class={`p-2 md:p-3 font-mono text-lg ${step.isConclusion ? 'text-secondary font-bold' : 'text-on-surface'}`}>{step.formula}</td>
          <td class="p-2 md:p-3 font-body text-sm text-on-surface-variant italic">{step.justification}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
