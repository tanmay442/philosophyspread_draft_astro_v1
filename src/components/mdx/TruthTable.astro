---
interface Props {
  variables: string[];
  rows: { inputs: string[]; result: string }[];
}

const { variables, rows } = Astro.props;

const getColorClass = (val: string) => {
  if (val === 'T') return 'text-green-600 dark:text-green-500';
  if (val === 'F') return 'text-red-600 dark:text-red-500';
  return '';
};
---

<div class="overflow-x-auto my-8">
  <table class="w-full border-collapse border-2 border-secondary bg-surface-container-low text-on-surface">
    <thead>
      <tr>
        {variables.map((variable) => (
          <th class="border-2 border-secondary p-4 font-headline text-lg text-primary">{variable}</th>
        ))}
        <th class="border-2 border-secondary p-4 font-headline text-lg text-primary bg-secondary/10">Result</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr class="hover:bg-secondary/5 transition-colors">
          {row.inputs.map((input) => (
            <td class={`border-2 border-secondary p-4 text-center font-mono text-sm font-bold ${getColorClass(input)}`}>{input}</td>
          ))}
          <td class={`border-2 border-secondary p-4 text-center font-mono text-sm font-bold bg-secondary/5 ${getColorClass(row.result)}`}>{row.result}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
