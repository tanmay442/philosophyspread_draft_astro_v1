---
import Icon from '../ui/Icon.astro';

interface Props {
  tag: string;
  time?: string;
  content: string;
  href?: string;
  bgClass?: string;
  contentClass?: string;
  icon?: string;
}

const {
  tag,
  time = '12:00 UTC',
  content,
  href = '#',
  bgClass = 'bg-white',
  contentClass = 'font-headline text-2xl leading-tight text-secondary font-semibold origin-left transition-transform duration-200 group-hover:[transform:skewX(-6deg)]',
  icon,
} = Astro.props;
---

<div class={`relative break-inside-avoid border-2 border-secondary p-8 transition-[transform,box-shadow,background-color] duration-200 hard-offset-teal hover:bg-tertiary-fixed cursor-pointer group mb-8 ${bgClass}`}>
  <a href={href} class="absolute inset-0 z-10" aria-label={`Read bit ${tag}`}></a>
  <div class="flex justify-between items-start border-b border-outline-variant pb-4 mb-4">
    <span class="font-label text-[10px] font-bold text-primary">{tag}</span>
    <span class="font-label text-[10px] text-on-surface-variant opacity-60">{time}</span>
  </div>
  <p class={contentClass} set:html={content} />
  {icon && (
    <div class="mt-6 flex justify-end">
      <Icon name={icon} class="h-5 w-5 text-secondary" />
    </div>
  )}
</div>
