---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import LogicCard from '../components/cards/LogicCard.astro';
---

<BaseLayout title="Logic Modules | Philosophy Spread">
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20">
    <!-- Header Section -->
    <header class="max-w-7xl mx-auto mb-16">
      <div class="font-label text-xs text-secondary mb-4 tracking-[0.2em] uppercase">[ Catalog / Systems of Thought ]</div>
      <h1 class="text-6xl md:text-8xl font-bold italic tracking-tighter text-secondary mb-6">Logic Modules</h1>
      <p class="max-w-2xl text-xl text-on-surface-variant leading-relaxed font-body">
        A rigorous directory of philosophical frameworks and logical structures. Each module serves as a building block for the Stoic mind, presented without the distraction of imagery.
      </p>
    </header>

    <!-- Multi-column grid layout -->
    <section class="max-w-7xl mx-auto">
      <div class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
        <LogicCard 
          moduleNumber="MODULE L-01"
          title="Virtue Ethics"
          description="The exploration of character and the role of virtue in determining right action. Focuses on the inherent quality of the individual."
        />

        <LogicCard 
          moduleNumber="MODULE L-02"
          title="Logical Fallacies"
          description="Identifying structural errors in reasoning. A catalog of cognitive biases and argumentative missteps that obscure objective truth."
        />

        <LogicCard 
          moduleNumber="MODULE L-03"
          title="Epistemology"
          description="The study of knowledge itself. Examining the nature of belief, justification, and the limits of human understanding."
        />

        <LogicCard 
          moduleNumber="MODULE L-04"
          title="Propositional Calculus"
          description="A formal system in mathematical logic that deals with propositions and connective operators. The foundational algebra of thought."
        />

        <LogicCard 
          moduleNumber="MODULE L-05"
          title="Syllogistic Reasoning"
          description="Aristotelian logic mapping the deductive arguments where a conclusion is drawn from two premises. Bedrock of classic discourse."
          titleClass="text-3xl italic"
        />

        <LogicCard 
          moduleNumber="MODULE L-06"
          title="Deontology"
          description="Normative ethical theory that judges morality based on rules. Focuses on the concepts of duty and obligation above outcomes."
        />

        <LogicCard 
          moduleNumber="MODULE L-07"
          title="Inductive Logic"
          description="Reasoning from specific instances to general principles. Exploring probability, evidence, and the scientific method of inquiry."
        />

        <LogicCard 
          moduleNumber="MODULE L-08"
          title="Categorical Imperative"
          description="Kantian principle of universality. Acts only according to that maxim whereby you can will it to become a universal law."
        />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
