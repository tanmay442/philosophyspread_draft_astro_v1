---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import LogicCard from '../../../components/cards/LogicCard.astro';
import { paginateItems, parsePageNumber } from '../../../utils/pagination';

const pageNumber = parsePageNumber(Astro.params.page);
if (!pageNumber) {
  return new Response('Not found', { status: 404 });
}

const modules = await getCollection('logicModules');
const sortedModules = modules.sort((a, b) => a.data.moduleNumber.localeCompare(b.data.moduleNumber));

const page = paginateItems(sortedModules, {
  pageNumber,
  pageSize: 4,
  basePath: '/logic-modules',
});

if (!page) {
  return new Response('Not found', { status: 404 });
}
---

<BaseLayout
  title={`Logic Modules - Page ${page.currentPage} | Philosophy Spread`}
  description={`Browse page ${page.currentPage} of logic modules covering argument structure, reasoning, and formal logic fundamentals.`}
  keywords={['logic modules', 'formal logic', 'reasoning skills', 'critical reasoning']}
>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20">
    <header class="max-w-7xl mx-auto mb-16">
      <div class="font-label text-xs text-primary mb-4 tracking-[0.2em] uppercase">[ Foundation ]</div>
      <h1 class="text-6xl md:text-8xl font-bold italic tracking-tighter text-secondary mb-6">Logic Modules</h1>
      <p class="max-w-2xl text-xl text-on-surface-variant leading-relaxed font-body">
        Master the fundamentals of formal logic, reasoning, and cognitive defense. 
      </p>
      <br/>
      <div class="font-label text-xs text-primary mb-4 tracking-[0.2em] uppercase">Page {page.currentPage} of {page.lastPage}.</div>
    </header>

    <section class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {page.items.map((module) => (
          <a href={`/logic-modules/${module.id}`} class="block group">
            <LogicCard 
              moduleNumber={module.data.moduleNumber}
              title={module.data.title} 
              description={module.data.description} 
            />
          </a>
        ))}
      </div>
      
      <nav class="mt-16 flex justify-center items-center space-x-4">
        {page.url.prev ? (
          <a href={page.url.prev} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            &lt;- Previous
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            &lt;- Previous
          </span>
        )}
        
        <span class="font-label text-xs tracking-widest text-secondary">
          {page.currentPage} / {page.lastPage}
        </span>
        
        {page.url.next ? (
          <a href={page.url.next} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            Next -&gt;
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            Next -&gt;
          </span>
        )}
      </nav>
    </section>
  </main>

  <Footer />
</BaseLayout>
