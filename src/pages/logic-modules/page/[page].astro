---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import LogicCard from '../../../components/cards/LogicCard.astro';

const pageNumber = Number.parseInt(Astro.params.page ?? '1', 10);

if (!Number.isInteger(pageNumber) || pageNumber < 1) {
  return new Response('Not found', { status: 404 });
}

const modules = await getCollection('logicModules');
const sortedModules = modules.sort((a: CollectionEntry<'logicModules'>, b: CollectionEntry<'logicModules'>) => a.data.moduleNumber.localeCompare(b.data.moduleNumber));
const pageSize = 4;
const lastPage = Math.max(1, Math.ceil(sortedModules.length / pageSize));

if (pageNumber > lastPage) {
  return new Response('Not found', { status: 404 });
}

const start = (pageNumber - 1) * pageSize;
const end = start + pageSize;
const pageData: CollectionEntry<'logicModules'>[] = sortedModules.slice(start, end);

const page = {
  data: pageData,
  currentPage: pageNumber,
  lastPage,
  url: {
    prev: pageNumber > 1 ? `/logic-modules/page/${pageNumber - 1}` : null,
    next: pageNumber < lastPage ? `/logic-modules/page/${pageNumber + 1}` : null,
  },
};
---

<BaseLayout title={`Logic Modules - Page ${page.currentPage} | Philosophy Spread`}>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20">
    <header class="max-w-7xl mx-auto mb-16">
      <div class="font-label text-xs text-primary mb-4 tracking-[0.2em] uppercase">[ Foundation ]</div>
      <h1 class="text-6xl md:text-8xl font-bold italic tracking-tighter text-secondary mb-6">Logic Modules</h1>
      <p class="max-w-2xl text-xl text-on-surface-variant leading-relaxed font-body">
        Master the fundamentals of formal logic, reasoning, and cognitive defense. Page {page.currentPage} of {page.lastPage}.
      </p>
    </header>

    <section class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {page.data.map((module: CollectionEntry<'logicModules'>) => (
          <a href={`/logic-modules/${module.id}`} class="block group">
            <LogicCard 
              moduleNumber={module.data.moduleNumber}
              title={module.data.title} 
              description={module.data.description} 
            />
          </a>
        ))}
      </div>
      
      <nav class="mt-16 flex justify-center items-center space-x-4">
        {page.url.prev ? (
          <a href={page.url.prev} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            &lt;- Previous
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            &lt;- Previous
          </span>
        )}
        
        <span class="font-label text-xs tracking-widest text-secondary">
          {page.currentPage} / {page.lastPage}
        </span>
        
        {page.url.next ? (
          <a href={page.url.next} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            Next -&gt;
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            Next -&gt;
          </span>
        )}
      </nav>
    </section>
  </main>

  <Footer />
</BaseLayout>
