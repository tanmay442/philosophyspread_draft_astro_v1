---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import TruthTable from '../../components/mdx/TruthTable.astro';
import FormalProof from '../../components/mdx/FormalProof.astro';
import CodeBlock from '../../components/mdx/CodeBlock.astro';
import InteractiveQuiz from '../../components/mdx/InteractiveQuiz.astro';
import Blockquote from '../../components/mdx/Blockquote.astro';
import Callout from '../../components/mdx/callout.astro';

const slug = Astro.params.slug;
const modules = await getCollection('logicModules');
const sortedModules = modules.sort((a: CollectionEntry<'logicModules'>, b: CollectionEntry<'logicModules'>) => a.data.moduleNumber.localeCompare(b.data.moduleNumber));
const moduleIndex = sortedModules.findIndex((entry: CollectionEntry<'logicModules'>) => entry.id === slug);

if (moduleIndex === -1) {
  return new Response('Not found', { status: 404 });
}

const module = sortedModules[moduleIndex];
const prevModule = moduleIndex > 0 ? sortedModules[moduleIndex - 1] : null;
const nextModule = moduleIndex < sortedModules.length - 1 ? sortedModules[moduleIndex + 1] : null;
const { Content } = await render(module);

const components = {
  TruthTable,
  FormalProof,
  CodeBlock,
  InteractiveQuiz,
  Blockquote,
  Callout,
};
---

<BaseLayout title={`${module.data.title} | Logic Modules`}>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20 max-w-4xl mx-auto">
    <article>
      <header class="mb-16 border-b-2 border-secondary pb-12">
        <div class="flex items-center justify-between mb-6">
          <span class="font-label text-sm text-primary font-bold tracking-[0.2em] uppercase">
            [ {module.data.moduleNumber} ]
          </span>
          <span class="font-label text-xs border-2 border-secondary px-3 py-1 uppercase tracking-widest text-secondary">
            {module.data.difficulty}
          </span>
        </div>
        <h1 class="text-5xl md:text-7xl font-bold italic tracking-tighter text-secondary mb-6">
          {module.data.title}
        </h1>
        <p class="text-xl text-on-surface-variant leading-relaxed font-body">
          {module.data.description}
        </p>
        
        {module.data.prerequisites.length > 0 && (
          <div class="mt-8 p-4 bg-surface-container-low border-l-4 border-secondary">
            <h3 class="font-label text-xs uppercase tracking-widest text-secondary mb-2">Prerequisites:</h3>
            <ul class="flex flex-wrap gap-4">
              {module.data.prerequisites.map((prereq: string) => (
                <li class="font-body text-sm italic">{prereq}</li>
              ))}
            </ul>
          </div>
        )}
      </header>

      <div class="prose prose-xl max-w-3xl mx-auto font-body leading-relaxed
        prose-headings:font-headline prose-headings:text-secondary prose-headings:font-bold
        prose-h2:text-4xl prose-h2:mt-16 prose-h2:mb-6 prose-h2:border-b-2 prose-h2:border-outline prose-h2:pb-4
        prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-4
        prose-p:mb-8 prose-p:text-xl prose-p:text-on-surface
        prose-a:text-primary hover:prose-a:text-secondary
        prose-strong:text-on-surface prose-strong:font-bold
        prose-ul:list-square prose-ul:pl-6 prose-li:mb-3 prose-li:text-xl prose-li:text-on-surface
        prose-code:text-on-surface prose-code:bg-surface-container prose-code:px-2 prose-code:py-0.5">
        <Content components={components} />
      </div>
      
      <nav class="mt-20 md:mt-24 pt-8 border-t-2 border-secondary flex gap-3 sm:gap-4 md:gap-8">
        {prevModule ? (
          <a href={`/logic-modules/${prevModule.id}`} class="group flex flex-1 min-w-0 h-[8.5rem] sm:h-[9.25rem] md:h-[10rem] flex-col justify-between items-start p-3 sm:p-4 md:p-6 border-2 border-secondary/30 hover:border-secondary bg-surface-container-low/30 transition-colors">
            <span class="font-label text-[9px] sm:text-[10px] uppercase tracking-widest text-primary">&lt;- Previous Module</span>
            <span class="font-headline text-base sm:text-lg md:text-2xl leading-tight break-words group-hover:italic transition-all">{prevModule.data.title}</span>
          </a>
        ) : (
          <div class="flex-1 h-[8.5rem] sm:h-[9.25rem] md:h-[10rem] border-2 border-secondary/10 bg-surface-container-low/10"></div>
        )}
        
        {nextModule ? (
          <a href={`/logic-modules/${nextModule.id}`} class="group flex flex-1 min-w-0 h-[8.5rem] sm:h-[9.25rem] md:h-[10rem] flex-col justify-between items-start md:items-end text-left md:text-right p-3 sm:p-4 md:p-6 border-2 border-secondary/30 hover:border-secondary bg-surface-container-low/30 transition-colors">
            <span class="font-label text-[9px] sm:text-[10px] uppercase tracking-widest text-primary">Next Module -&gt;</span>
            <span class="font-headline text-base sm:text-lg md:text-2xl leading-tight break-words group-hover:italic transition-all">{nextModule.data.title}</span>
          </a>
        ) : (
          <div class="flex-1 h-[8.5rem] sm:h-[9.25rem] md:h-[10rem] border-2 border-secondary/10 bg-surface-container-low/10"></div>
        )}
      </nav>
    </article>
  </main>

  <Footer />
</BaseLayout>
