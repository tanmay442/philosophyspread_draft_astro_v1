---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Blockquote from '../components/mdx/Blockquote.astro';

const pages = await getCollection('pages');
const contributePage = pages.find((entry) => entry.id === 'contribute');

if (!contributePage) {
  return new Response('Not found', { status: 404 });
}

const { Content } = await render(contributePage);

const components = {
  Blockquote,
};
---

<BaseLayout title={`${contributePage.data.title} | Philosophy Spread`}>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20 max-w-4xl mx-auto">
    <article>
      <header class="mb-12">
        <a href="/" class="inline-flex items-center gap-2 text-primary hover:text-secondary transition-colors mb-6 font-label text-xs uppercase tracking-widest">
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Back to Home
        </a>
        
        <h1 class="text-4xl md:text-6xl font-bold italic tracking-tighter text-secondary mb-4">
          {contributePage.data.title}
        </h1>
        
        <p class="text-on-surface-variant leading-relaxed font-body">
          Last Updated: {contributePage.data.lastUpdated}
        </p>
      </header>

      <div class="prose prose-xl max-w-none font-body leading-relaxed
        prose-headings:font-headline prose-headings:text-secondary prose-headings:font-bold
        prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:border-b-2 prose-h2:border-outline prose-h2:pb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4
        prose-p:mb-6 prose-p:text-lg prose-p:text-on-surface
        prose-a:text-primary prose-a:underline hover:prose-a:text-secondary
        prose-strong:text-on-surface prose-strong:font-bold
        prose-ul:list-disc prose-ul:pl-6 prose-li:mb-2 prose-li:text-on-surface prose-li:pl-2
        prose-ul ul:list-[circle] prose-ul ul:pl-6">
        <Content components={components} />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>