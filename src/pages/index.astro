---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Hero from '../components/sections/Hero.astro';
import LogicModules from '../components/sections/LogicModules.astro';
import DailyBits from '../components/sections/DailyBits.astro';
import Essays from '../components/sections/Essays.astro';
import GetInvolved from '../components/sections/GetInvolved.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Philosophy Spread | The Logical Manuscript"
  description="Explore philosophy essays, logic modules, and 48hrs-bits designed to sharpen reasoning and deepen reflection."
  keywords={['philosophy', 'logic', 'critical thinking', 'essays', 'reasoning']}
>
  <Header />
  <main class="pt-20">
    <Hero />
    <LogicModules />
    <DailyBits />
    <Essays />
    <GetInvolved />
  </main>
  <Footer />
</BaseLayout>
