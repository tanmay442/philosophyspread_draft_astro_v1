---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Blockquote from '../../components/mdx/Blockquote.astro';

const slug = Astro.params.slug;

if (slug && /^\d+$/.test(slug)) {
  return Astro.redirect(`/essays/page/${slug}`, 301);
}

const essays = await getCollection('essays');
const essay = essays.find((entry: CollectionEntry<'essays'>) => entry.id === slug);

if (!essay) {
  return new Response('Not found', { status: 404 });
}

const { Content } = await render(essay);
const siteUrl = Astro.site ?? new URL('https://philosophyspread.live');
const essayUrl = new URL(Astro.url.pathname, siteUrl).toString();
const essayImageUrl = essay.data.imageSrc.startsWith('http://') || essay.data.imageSrc.startsWith('https://')
  ? essay.data.imageSrc
  : new URL(essay.data.imageSrc, siteUrl).toString();

const articleStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: essay.data.title,
  description: essay.data.description,
  datePublished: essay.data.pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: essay.data.author,
  },
  image: [essayImageUrl],
  mainEntityOfPage: essayUrl,
  publisher: {
    '@type': 'Organization',
    name: 'Philosophy Spread',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', siteUrl).toString(),
    },
  },
};

const components = {
  Blockquote,
};
---

<BaseLayout
  title={`${essay.data.title} | Philosophy Spread`}
  description={essay.data.description}
  image={essay.data.imageSrc}
  keywords={['philosophy essay', 'critical thinking', essay.data.category, ...essay.data.tags]}
  type="article"
  structuredData={articleStructuredData}
>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20 max-w-4xl mx-auto">
    <article>
      <header class="mb-12 text-center">
        <div class="font-label text-xs text-primary mb-4 tracking-[0.2em] uppercase">
          [ {essay.data.category} ]
        </div>
        <h1 class="text-5xl md:text-7xl font-bold italic tracking-tighter text-secondary mb-6">
          {essay.data.title}
        </h1>
        <p class="text-xl text-on-surface-variant leading-relaxed font-body mb-8">
          {essay.data.description}
        </p>
        <div class="flex items-center justify-center space-x-4 font-label text-xs uppercase tracking-widest text-secondary">
          <span>By {essay.data.author}</span>
          <span>&bull;</span>
          <span>&bull;</span>
          <time datetime={essay.data.pubDate.toISOString()}>
            {essay.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
      </header>

      <div class="max-w-3xl mx-auto mb-16 group">
        <div class="aspect-video overflow-hidden border-2 border-secondary bg-white">
          <img 
            src={essay.data.imageSrc} 
            alt={essay.data.imageAlt} 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            referrerpolicy="no-referrer"
          />
        </div>
      </div>

      <div class="prose prose-xl max-w-3xl mx-auto font-body leading-relaxed
        prose-headings:font-headline prose-headings:text-secondary prose-headings:font-bold
        prose-h2:text-4xl prose-h2:mt-16 prose-h2:mb-6 prose-h2:border-b-2 prose-h2:border-outline prose-h2:pb-4
        prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-4
        prose-p:mb-8 prose-p:text-xl prose-p:text-on-surface
        prose-a:text-primary hover:prose-a:text-secondary
        prose-strong:text-on-surface prose-strong:font-bold
        prose-ul:list-square prose-ul:pl-6 prose-li:mb-3 prose-li:text-xl prose-li:text-on-surface
        prose-blockquote:not-italic prose-blockquote:border-none prose-blockquote:pl-0">
        <Content components={components} />
      </div>
      
      {essay.data.tags.length > 0 && (
        <div class="mt-16 pt-8 border-t-2 border-secondary flex flex-wrap gap-2">
          {essay.data.tags.map((tag: string) => (
            <span class="font-label text-[10px] uppercase tracking-widest border border-secondary px-3 py-1 text-secondary">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <div class="mt-12 pt-8 border-t border-outline-variant text-center">
        <a href="/essays/page/1" class="font-label text-xs text-primary uppercase tracking-widest hover:text-secondary transition-colors">
          &lt;- Back to Essays
        </a>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
