---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import EssayCard from '../../../components/cards/EssayCard.astro';

const pageNumber = Number.parseInt(Astro.params.page ?? '1', 10);

if (!Number.isInteger(pageNumber) || pageNumber < 1) {
  return new Response('Not found', { status: 404 });
}

const essays = await getCollection('essays');
const sortedEssays = essays.sort((a: CollectionEntry<'essays'>, b: CollectionEntry<'essays'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const pageSize = 9;
const lastPage = Math.max(1, Math.ceil(sortedEssays.length / pageSize));

if (pageNumber > lastPage) {
  return new Response('Not found', { status: 404 });
}

const start = (pageNumber - 1) * pageSize;
const end = start + pageSize;
const pageData: CollectionEntry<'essays'>[] = sortedEssays.slice(start, end);

const page = {
  data: pageData,
  currentPage: pageNumber,
  lastPage,
  url: {
    prev: pageNumber > 1 ? `/essays/page/${pageNumber - 1}` : null,
    next: pageNumber < lastPage ? `/essays/page/${pageNumber + 1}` : null,
  },
};
---

<BaseLayout title={`Essays - Page ${page.currentPage} | Philosophy Spread`}>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20">
    <header class="max-w-7xl mx-auto mb-16">
      <div class="font-label text-xs text-secondary mb-4 tracking-[0.2em] uppercase">[ The Archives ]</div>
      <h1 class="text-6xl md:text-8xl font-bold italic tracking-tighter text-secondary mb-6">Essays</h1>
      <p class="max-w-2xl text-xl text-on-surface-variant leading-relaxed font-body">
        Long-form explorations of contemporary issues through classical lenses. Page {page.currentPage} of {page.lastPage}.
      </p>
    </header>

    <section class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {page.data.map((essay: CollectionEntry<'essays'>) => (
          <EssayCard 
            tag={`[ ${essay.data.category} ]`}
            title={essay.data.title}
            description={essay.data.description}
            readTime={essay.data.readTime}
            imageSrc={essay.data.imageSrc}
            imageAlt={essay.data.imageAlt}
            href={`/essays/${essay.id}`}
          />
        ))}
      </div>
      
      <nav class="mt-16 flex justify-center items-center space-x-4">
        {page.url.prev ? (
          <a href={page.url.prev} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            &lt;- Newer
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            &lt;- Newer
          </span>
        )}
        
        <span class="font-label text-xs tracking-widest text-secondary">
          {page.currentPage} / {page.lastPage}
        </span>
        
        {page.url.next ? (
          <a href={page.url.next} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            Older -&gt;
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            Older -&gt;
          </span>
        )}
      </nav>
    </section>
  </main>

  <Footer />
</BaseLayout>