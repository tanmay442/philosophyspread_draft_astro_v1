---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import EssayCard from '../../../components/cards/EssayCard.astro';
import { paginateItems, parsePageNumber } from '../../../utils/pagination';

const pageNumber = parsePageNumber(Astro.params.page);
if (!pageNumber) {
  return new Response('Not found', { status: 404 });
}

const essays = await getCollection('essays');
const sortedEssays = essays.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const page = paginateItems(sortedEssays, {
  pageNumber,
  pageSize: 9,
  basePath: '/essays',
});

if (!page) {
  return new Response('Not found', { status: 404 });
}
---

<BaseLayout
  title={`Essays - Page ${page.currentPage} | Philosophy Spread`}
  description={`Browse page ${page.currentPage} of Philosophy Spread essays: long-form philosophical writing on logic, ethics, and critical thought.`}
  keywords={['philosophy essays', 'critical thinking', 'long-form philosophy', 'logic']}
>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20">
    <header class="max-w-7xl mx-auto mb-16">
      <div class="font-label text-xs text-secondary mb-4 tracking-[0.2em] uppercase">[ The Archives ]</div>
      <h1 class="text-6xl md:text-8xl font-bold italic tracking-tighter text-secondary mb-6">Essays</h1>
      <p class="max-w-2xl text-xl text-on-surface-variant leading-relaxed font-body">
        Long-form explorations of contemporary issues through classical lenses. 
      </p>
      <br/>
      <div class="font-label text-xs text-secondary mb-4 tracking-[0.2em] uppercase">Page {page.currentPage} of {page.lastPage}.</div>
    </header>

    <section class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {page.items.map((essay) => (
          <EssayCard 
            tag={`[ ${essay.data.category} ]`}
            title={essay.data.title}
            description={essay.data.description}
            readTime={essay.data.pubDate}
            imageSrc={essay.data.imageSrc}
            imageAlt={essay.data.imageAlt}
            href={`/essays/${essay.id}`}
          />
        ))}
      </div>
      
      <nav class="mt-16 flex justify-center items-center space-x-4">
        {page.url.prev ? (
          <a href={page.url.prev} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            &lt;- Newer
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            &lt;- Newer
          </span>
        )}
        
        <span class="font-label text-xs tracking-widest text-secondary">
          {page.currentPage} / {page.lastPage}
        </span>
        
        {page.url.next ? (
          <a href={page.url.next} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            Older -&gt;
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            Older -&gt;
          </span>
        )}
      </nav>
    </section>
  </main>

  <Footer />
</BaseLayout>
