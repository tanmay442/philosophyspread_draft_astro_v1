---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import BitCard from '../../../components/cards/BitCard.astro';

const pageNumber = Number.parseInt(Astro.params.page ?? '1', 10);

if (!Number.isInteger(pageNumber) || pageNumber < 1) {
  return new Response('Not found', { status: 404 });
}

const bits = await getCollection('bits');
const sortedBits = bits.sort((a: CollectionEntry<'bits'>, b: CollectionEntry<'bits'>) => b.data.timestamp.valueOf() - a.data.timestamp.valueOf());
const pageSize = 12;
const lastPage = Math.max(1, Math.ceil(sortedBits.length / pageSize));

if (pageNumber > lastPage) {
  return new Response('Not found', { status: 404 });
}

const start = (pageNumber - 1) * pageSize;
const end = start + pageSize;
const pageData: CollectionEntry<'bits'>[] = sortedBits.slice(start, end);

const page = {
  data: pageData,
  currentPage: pageNumber,
  lastPage,
  url: {
    prev: pageNumber > 1 ? `/bits/page/${pageNumber - 1}` : null,
    next: pageNumber < lastPage ? `/bits/page/${pageNumber + 1}` : null,
  },
};
---

<BaseLayout title={`48hrs-bits - Page ${page.currentPage} | Philosophy Spread`}>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20">
    <header class="max-w-7xl mx-auto mb-16">
      <div class="font-label text-xs text-primary mb-4 tracking-[0.2em] uppercase">[ Raw Feed ]</div>
      <h1 class="text-6xl md:text-8xl font-bold italic tracking-tighter text-secondary mb-6">48hrs-bits</h1>
      <p class="max-w-2xl text-xl text-on-surface-variant leading-relaxed font-body">
        Unfiltered philosophical fragments, paradoxes, and observations.
      </p>
      <br/>
      <div class="font-label text-xs text-primary mb-4 tracking-[0.2em] uppercase">Page {page.currentPage} of {page.lastPage}.</div>
    </header>

    <section class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {page.data.map((bit: CollectionEntry<'bits'>) => (
          <BitCard 
            tag={`#${bit.data.bitNumber} / ${bit.data.category.toUpperCase()}`}
            content={bit.data.content}
            time={bit.data.timestamp.toLocaleString('en-US', { timeZone: 'UTC', dateStyle: 'medium', timeStyle: 'short' }) + ' UTC'}
            href={`/bits/${bit.id}`}
          />
        ))}
      </div>
      
      <nav class="mt-16 flex justify-center items-center space-x-4">
        {page.url.prev ? (
          <a href={page.url.prev} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            &lt;- Newer
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            &lt;- Newer
          </span>
        )}
        
        <span class="font-label text-xs tracking-widest text-secondary">
          {page.currentPage} / {page.lastPage}
        </span>
        
        {page.url.next ? (
          <a href={page.url.next} class="font-label text-xs uppercase tracking-widest border-2 border-secondary px-6 py-3 hover:bg-secondary hover:text-surface transition-colors">
            Older -&gt;
          </a>
        ) : (
          <span class="font-label text-xs uppercase tracking-widest border-2 border-secondary/30 text-secondary/30 px-6 py-3 cursor-not-allowed">
            Older -&gt;
          </span>
        )}
      </nav>
    </section>
  </main>

  <Footer />
</BaseLayout>