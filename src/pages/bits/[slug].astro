---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Callout from '../../components/mdx/callout.astro';
import Icon from '../../components/ui/Icon.astro';

const slug = Astro.params.slug;

if (slug && /^\d+$/.test(slug)) {
  return Astro.redirect(`/bits/page/${slug}`, 301);
}

const bits = await getCollection('bits');
const bit = bits.find((entry: CollectionEntry<'bits'>) => entry.id === slug);

if (!bit) {
  return new Response('Not found', { status: 404 });
}

const { Content } = await render(bit);
const bitDescription = bit.data.content.length > 157
  ? `${bit.data.content.slice(0, 157)}...`
  : bit.data.content;
---

<BaseLayout
  title={`Bit ${bit.data.bitNumber} | Philosophy Spread`}
  description={bitDescription}
  keywords={['philosophy bit', '48hrs-bits', bit.data.category, 'thought experiment']}
>
  <Header />
  
  <main class="pt-32 px-6 md:px-12 pb-20 max-w-3xl mx-auto min-h-[calc(100vh-200px)]">
    <article class="relative">
      <header class="mb-12 border-b-2 border-secondary pb-8">
        <div class="flex items-center gap-4 mb-6">
          <span class="bg-primary text-on-primary font-label text-xs px-3 py-1 uppercase tracking-widest">
            Bit {bit.data.bitNumber}
          </span>
          <span class="font-label text-xs text-secondary uppercase tracking-widest">
            {bit.data.category}
          </span>
        </div>
        <time datetime={bit.data.timestamp.toISOString()} class="font-label text-sm text-on-surface-variant opacity-80 uppercase tracking-widest">
          {bit.data.timestamp.toLocaleString('en-US', { timeZone: 'UTC', dateStyle: 'long', timeStyle: 'short' })} UTC
        </time>
        <div class="mt-3 font-label text-xs text-on-surface-variant uppercase tracking-widest">
          By {bit.data.author}
        </div>
      </header>
      
      <div class="prose prose-xl prose-slate dark:prose-invert max-w-none font-body text-secondary leading-relaxed mb-16
        prose-p:text-2xl md:prose-p:text-3xl prose-p:leading-relaxed prose-p:text-secondary
        prose-a:text-primary hover:prose-a:text-secondary
        prose-strong:text-secondary prose-strong:font-bold
        prose-blockquote:border-l-4 prose-blockquote:border-primary prose-blockquote:pl-6 prose-blockquote:italic">
        <Content components={{ Callout }} />
      </div>
      
      <div class="flex justify-center border-t-2 border-secondary pt-12">
        <a href="/bits/page/1" class="font-label text-sm text-primary uppercase tracking-widest hover:text-secondary transition-colors flex items-center group">
          <Icon name="arrow_back" class="mr-2 h-4 w-4 group-hover:-translate-x-1 transition-transform" />
          Back to Feed
        </a>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
