---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import EssayCard from '../components/cards/EssayCard.astro';
---

<BaseLayout title="All Essays | Philosophy Spread">
  <Header />
  
  <main class="pt-32 pb-20 max-w-7xl mx-auto px-6">
    <!-- Essays Grid - Standardized Scale -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <EssayCard 
        tag="Featured Manuscript"
        title="The Architecture of Silence"
        description="Investigating the spatial ethics of noise in a hyper-connected world and the stoic pursuit of intellectual sanctuary."
        readTime="18 MIN READ"
        imageSrc="https://lh3.googleusercontent.com/aida-public/AB6AXuBSylLoh6H6Tq0Me2cED09fy1V4zplU4b7tSXNM9bi8_HPC-CLe1MEl8dy9DSKMXJ6NMYWvyU6oOHd_fL8YT4tGPwMA1FcCpbyk2Ef82lL9vvmmnv1H9ki1qVXT40nx5BwV-futlxuO_6Y-pK502jO9harjq2uQNbZUSEC4WhHi9xGg_JnSaRFnAhQjGef1mjL6EbRKk54owCwt-o0fcb_uJ7Osk-S3PYFVOD9cOd0Y7sB2AmglNK83uunsbmKBWgeji-bY37IyJ7w"
        imageAlt="Modernist concrete architecture library interior"
        textClass="text-secondary italic"
      />

      <EssayCard 
        tag="Ethics Lab"
        title="The Calculus of Regret"
        description="A mathematical approach to past decisions and the stoic refusal to dwell on non-linear outcomes."
        readTime="24 Min Read"
        imageSrc="https://lh3.googleusercontent.com/aida-public/AB6AXuD_ksJYYReSZB_VY9He8EotSeaDRNyao1X9yNVCT3Fx5oJXyrd7864J8nHyLZ63V1f9gZcH6YUkZnw1iUxtLDIB1an-YhDbXLsXrCR3aBd03PNY6Z-hHNP7iw4zGsFkpict82ayG_I_1uSXJWe5zVzXQUWWsawalDzO0ckEx-K6zqM4W9qYYY-pLxwSA46ilk63j8wAydFTGkfalMJMlN66wIE39uSEHarH1bSbA1cDKKWSUD_ajX9aywnC2x64eT3mj83vfKtAggg"
        imageAlt="Abstract geometry casting hard shadows"
        imageClass="grayscale opacity-80 mix-blend-multiply group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
        textClass="text-secondary italic"
        buttonText="Observe More"
      />

      <EssayCard 
        tag="Bits"
        title="The Lens of Epictetus"
        description="Reframing visual perception as a moral choice rather than a sensory reflex."
        readTime="05 Min Read"
        imageSrc="https://lh3.googleusercontent.com/aida-public/AB6AXuCLyFp2XvoRelAxPefn4czcRpOewkhA3-aHpoqSLl07OZFkE4cexDHZHu8z2pOuOX0L49AcY-FKxcUFEtvvNfiUkVxzIKV5D19FuE9UsGewXoe7G8oVMUKssgfJMtWMjChwF6sXa_bClf_PJ-2xeDK2Kc0DttyT-xq5QKEvb50OrN9ai5UsnLL4qd4spIDiOBANMKMicT7Tvos-Whv_kz4z6ubaSR1TjjY3JPL2SLSjKs5F1c_4wTI-0_T1albwQoGcAXE2O-_YJTE"
        imageAlt="Vintage scientific lens reflecting stars"
        buttonText="Observe More"
      />

      <EssayCard 
        tag="Logic Modules"
        title="Syllogistic Drift"
        description="How small failures in logical premises lead to systemic ethical collapses over decades."
        readTime="12 Min Read"
        imageSrc="https://lh3.googleusercontent.com/aida-public/AB6AXuDzWBcYcOq5RA2eF-5ZHP7Tzcnb8i0h710eQtjLp6LVAN8I7v_E3E_EoEqm6hBbtip2i4mWDJjOptYlIUP6vYimDNKa_HAVKMbaGVAu-ySUWrWsfsC9vlY_b-MT6sUgcGbnyuI3ZZNYvWhaujfidb6o-heEJH8pfENMfVro6DFJlgcmJ1t9gEzWd1-FAWeX5F-ZSPWnzcNrWJ3ARC0MVjozyL8QX9o3VTczlCHCAupW47GHm7O66-IiDSvw2Fr3SOCeZ33G_4yjBf0"
        imageAlt="Monochrome close-up of an ancient Greek marble philosopher statue"
        imageClass="filter grayscale contrast-125 transition-all duration-700 group-hover:grayscale-0"
      />

      <EssayCard 
        tag="Archives"
        title="Iron &amp; Ink"
        description="The physical cost of philosophical production in the 19th century and its impact on modern thought."
        readTime="42 Min Read"
        imageSrc="https://lh3.googleusercontent.com/aida-public/AB6AXuD_ksJYYReSZB_VY9He8EotSeaDRNyao1X9yNVCT3Fx5oJXyrd7864J8nHyLZ63V1f9gZcH6YUkZnw1iUxtLDIB1an-YhDbXLsXrCR3aBd03PNY6Z-hHNP7iw4zGsFkpict82ayG_I_1uSXJWe5zVzXQUWWsawalDzO0ckEx-K6zqM4W9qYYY-pLxwSA46ilk63j8wAydFTGkfalMJMlN66wIE39uSEHarH1bSbA1cDKKWSUD_ajX9aywnC2x64eT3mj83vfKtAggg"
        imageAlt="Abstract ink and iron texture"
        bgClass="bg-secondary"
        textClass="text-white"
        tagClass="text-secondary-fixed"
        buttonClass="text-white hover:text-secondary-fixed"
        buttonText="View Archive"
        imageClass="transition-transform duration-700 group-hover:scale-110"
      />

      <EssayCard 
        tag="Ethics Lab"
        title="Static Noise"
        description="A defense of boredom as the primary driver of creative ethics and systemic patience."
        readTime="08 Min Read"
        imageSrc="https://lh3.googleusercontent.com/aida-public/AB6AXuBSylLoh6H6Tq0Me2cED09fy1V4zplU4b7tSXNM9bi8_HPC-CLe1MEl8dy9DSKMXJ6NMYWvyU6oOHd_fL8YT4tGPwMA1FcCpbyk2Ef82lL9vvmmnv1H9ki1qVXT40nx5BwV-futlxuO_6Y-pK502jO9harjq2uQNbZUSEC4WhHi9xGg_JnSaRFnAhQjGef1mjL6EbRKk54owCwt-o0fcb_uJ7Osk-S3PYFVOD9cOd0Y7sB2AmglNK83uunsbmKBWgeji-bY37IyJ7w"
        imageAlt="Silent geometric space"
        imageClass="grayscale transition-all duration-700 group-hover:grayscale-0"
        buttonText="Read Essay"
      />
    </div>

    <!-- Pagination -->
    <div class="mt-20 flex justify-center items-center gap-4">
      <button class="w-10 h-10 border-2 border-secondary flex items-center justify-center font-label text-xs hover:bg-tertiary-fixed transition-colors">
        <span class="material-symbols-outlined text-sm" data-icon="chevron_left">chevron_left</span>
      </button>
      <button class="w-10 h-10 border-2 border-secondary bg-primary text-white flex items-center justify-center font-label text-xs">01</button>
      <button class="w-10 h-10 border-2 border-secondary flex items-center justify-center font-label text-xs hover:bg-tertiary-fixed transition-colors">02</button>
      <button class="w-10 h-10 border-2 border-secondary flex items-center justify-center font-label text-xs hover:bg-tertiary-fixed transition-colors">03</button>
      <span class="font-label text-xs px-2">...</span>
      <button class="w-10 h-10 border-2 border-secondary flex items-center justify-center font-label text-xs hover:bg-tertiary-fixed transition-colors">12</button>
      <button class="w-10 h-10 border-2 border-secondary flex items-center justify-center font-label text-xs hover:bg-tertiary-fixed transition-colors">
        <span class="material-symbols-outlined text-sm" data-icon="chevron_right">chevron_right</span>
      </button>
    </div>
  </main>

  <Footer />
</BaseLayout>
